GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=2048
GROQ_TIMEOUT=30

CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

LLM_PROVIDER_ORDER=groq,cerebras,gemini,ollama

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DEVICE=cpu

CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=personal_knowledge
CHROMA_DISTANCE_METRIC=cosine

RETRIEVAL_TOP_K=10
SIMILARITY_THRESHOLD=0.3

CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=50

RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
SQLITE_PATH=./data/sqlite/metadata.db
CONVERSATIONS_DB_PATH=./data/sqlite/conversations.db

WATCH_ENABLED=true
WATCH_DIRECTORY=./data/raw
WATCH_DEBOUNCE_SECONDS=2

API_HOST=0.0.0.0
API_PORT=8000

LOG_LEVEL=INFO
LOG_FORMAT=json

# v1.5 Quality Layer
BM25_ENABLED=true
BM25_WEIGHT=0.3
BM25_INDEX_PATH=./data/cache/bm25_index

RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_TOP_K=5
RERANKER_DEVICE=cpu

CACHE_ENABLED=true
CACHE_DIR=./data/cache/query_cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=500

RATE_LIMIT_ENABLED=true
GROQ_REQUESTS_PER_MINUTE=30
GROQ_TOKENS_PER_MINUTE=6000

# v2.0 Multi-Modal
OCR_ENGINE=easyocr
OCR_LANGUAGES=en
OCR_CONFIDENCE_THRESHOLD=0.3
OCR_GPU=false

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=en
MAX_AUDIO_DURATION_MINUTES=60

VISION_ENABLED=true
VISION_PROVIDER=gemini
VISION_MODEL=gemini-2.5-flash
VISION_MAX_TOKENS=500

THUMBNAIL_SIZE=300
THUMBNAIL_DIR=./data/processed/thumbnails
TRANSCRIPTS_DIR=./data/processed/transcripts
OCR_RESULTS_DIR=./data/processed/ocr_results

SUPPORTED_IMAGE_EXTENSIONS=.png,.jpg,.jpeg,.webp,.gif,.bmp,.tiff
SUPPORTED_AUDIO_EXTENSIONS=.mp3,.wav,.m4a,.ogg,.flac,.wma,.aac

# v3.0 Agentic + Integrations
AGENTIC_ROUTER_ENABLED=true
DIGEST_DAILY_CRON=0 20 * * *
DIGEST_WEEKLY_CRON=0 18 * * SUN
INTEGRATION_SYNC_CRON=0 */6 * * *
TOKEN_ENCRYPTION_KEY=
LOCAL_AUTH_ENABLED=false
LOCAL_AUTH_PIN=
GENERAL_SEARCH_EXCLUDED_SOURCES=
